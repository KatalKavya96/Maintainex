DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
PORT=5001
CLIENT_URL="http://localhost:3000"
CLIENT_URLS="http://localhost:3000,https://your-maintainex-app.vercel.app"
JWT_SECRET="replace-with-a-long-random-secret"
SIGNUP_ADMIN_CODE="optional-admin-invite-code"
ALLOW_VERCEL_ORIGINS=true
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GITHUB_REDIRECT_URI="http://localhost:5001/api/github/callback"
# Optional separate callback if you use a second GitHub OAuth app for login.
GITHUB_AUTH_REDIRECT_URI=""
GITHUB_TOKEN_ENCRYPTION_KEY="replace-with-a-long-random-secret"
GITHUB_OAUTH_SCOPES="read:user user:email public_repo"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:5001/api/auth/oauth/google/callback"
RESEND_API_KEY=""
MAIL_FROM="Maintainex <noreply@maintainex.app>"
EMAIL_DNS_CHECK=true
