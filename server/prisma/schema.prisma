generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ActivityType {
  PR_REVIEWED
  PR_RAISED
  ISSUE_RAISED
  PR_CLOSED
  ISSUE_CLOSED
  COMMENTED
  MERGED
  OTHER
}

enum ActivityStatus {
  OPEN
  CLOSED
  MERGED
  REVIEWED
  APPROVED
  CHANGES_REQUESTED
  COMMENTED
  DRAFT
  OTHER
}

enum ReviewType {
  COMMENTED
  APPROVED
  CHANGES_REQUESTED
  REQUESTED_REVIEW
  NOT_APPLICABLE
}

enum ClosingReason {
  DUPLICATE
  STALE
  INVALID
  COMPLETED
  FIXED_IN_ANOTHER_PR
  NOT_REPRODUCIBLE
  AUTHOR_CLOSED
  MAINTAINER_CLOSED
  NOT_APPLICABLE
  OTHER
}

enum UserRole {
  ADMIN
  VIEWER
}

model User {
  id            String          @id @default(cuid())
  name          String
  username      String          @unique
  email         String          @unique
  passwordHash  String
  role          UserRole        @default(VIEWER)
  bio           String?         @db.Text
  githubUrl     String?
  linkedinUrl   String?
  portfolioUrl  String?
  skills        Json?
  mainOrganizations Json?
  activities    Activity[]
  organizations Organization[]
  repositories  Repository[]
  pins          Pin[]
  scheduledWork ScheduledWork[]
  goals         Goal[]
  following     Follow[]        @relation("UserFollowing")
  followers     Follow[]        @relation("UserFollowers")
  notifications Notification[]  @relation("UserNotifications")
  sentNotifications Notification[] @relation("NotificationActor")
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model Follow {
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  follower    User     @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId])
  @@index([followingId])
}

enum GoalMetric {
  PR_RAISED
  PR_REVIEWED
  ISSUE_RAISED
  ISSUE_CLOSED
  REPO_CONTRIBUTIONS
  TOTAL_ACTIVITY
  STREAK
}

enum GoalPeriod {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
  CUSTOM
}

model Goal {
  id          String     @id @default(cuid())
  userId      String
  title       String
  metric      GoalMetric
  target      Int
  period      GoalPeriod @default(MONTHLY)
  startsAt    DateTime?
  endsAt      DateTime?
  isCompleted Boolean    @default(false)
  completedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([metric])
  @@index([period])
}

enum NotificationType {
  SYSTEM
  SOCIAL
  GOAL
  SCHEDULE
  BADGE
  REMINDER
}

model Notification {
  id          String           @id @default(cuid())
  recipientId String
  actorId     String?
  type        NotificationType @default(SYSTEM)
  title       String
  body        String           @db.Text
  metadata    Json?
  readAt      DateTime?
  createdAt   DateTime         @default(now())
  recipient   User             @relation("UserNotifications", fields: [recipientId], references: [id], onDelete: Cascade)
  actor       User?            @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([recipientId])
  @@index([actorId])
  @@index([type])
  @@index([createdAt])
}

enum PinCategory {
  REPOSITORY
  ISSUE
  PULL_REQUEST
  DOCUMENTATION
  PROJECT_BOARD
  ORGANIZATION
  WEBSITE
  OTHER
}

enum ScheduledWorkType {
  PR_REVIEW
  ISSUE_WORK
  PR_TO_RAISE
  ISSUE_TO_RAISE
  BUG_FIX
  FEATURE_BUILD
  DOCUMENTATION
  TESTING
  OTHER
}

enum ScheduledWorkStatus {
  PLANNED
  IN_PROGRESS
  BLOCKED
  DONE
  CANCELLED
  POSTPONED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum WorkDifficulty {
  EASY
  MEDIUM
  HARD
}

model Pin {
  id             String      @id @default(cuid())
  userId         String
  title          String
  url            String
  description    String?     @db.Text
  category       PinCategory @default(WEBSITE)
  customCategory String?
  iconUrl        String?
  faviconUrl     String?
  imageUrl       String?
  isFavorite     Boolean     @default(false)
  isArchived     Boolean     @default(false)
  tags           Json?
  sortOrder      Int         @default(0)
  lastOpenedAt   DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([category])
  @@index([isFavorite])
  @@index([createdAt])
}

model ScheduledWork {
  id               String              @id @default(cuid())
  userId           String
  title            String
  type             ScheduledWorkType
  status           ScheduledWorkStatus @default(PLANNED)
  priority         Priority            @default(MEDIUM)
  organizationName String
  repositoryName   String
  itemNumber       Int?
  itemUrl          String?
  assignedToMe     Boolean             @default(false)
  assignedSince    DateTime?
  startDate        DateTime?
  dueDate          DateTime?
  completedAt      DateTime?
  estimatedHours   Float?
  actualHours      Float?
  labels           Json?
  tags             Json?
  difficulty       WorkDifficulty?
  context          String?             @db.Text
  plan             String?             @db.Text
  blockers         String?             @db.Text
  closingNotes     String?             @db.Text
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  user             User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([priority])
  @@index([type])
  @@index([dueDate])
  @@index([assignedToMe])
}

model Activity {
  id                       String         @id @default(cuid())
  userId                   String
  date                     DateTime
  activityType             ActivityType
  title                    String
  number                   String?
  link                     String?
  status                   ActivityStatus @default(OTHER)
  reviewType               ReviewType     @default(NOT_APPLICABLE)
  closingReason            ClosingReason  @default(NOT_APPLICABLE)
  description              String?        @db.Text
  notes                    String?        @db.Text
  tags                     Json?
  organizationId           String?
  repositoryId             String?
  organizationNameSnapshot String
  repositoryNameSnapshot   String
  organization             Organization?  @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  repository               Repository?    @relation(fields: [repositoryId], references: [id], onDelete: SetNull)
  user                     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt                DateTime       @default(now())
  updatedAt                DateTime       @updatedAt

  @@index([userId])
  @@index([date])
  @@index([activityType])
  @@index([organizationId])
  @@index([repositoryId])
}

model Organization {
  id           String       @id @default(cuid())
  userId       String
  name         String
  website      String?
  githubUrl    String?
  description  String?      @db.Text
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  repositories Repository[]
  activities   Activity[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@unique([userId, name])
  @@index([userId])
}

model Repository {
  id               String        @id @default(cuid())
  userId           String
  organizationId   String
  name             String
  githubUrl        String?
  description      String?       @db.Text
  primaryTechStack String?
  isActive         Boolean       @default(true)
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization     Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  activities       Activity[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@unique([userId, organizationId, name])
  @@index([userId])
  @@index([organizationId])
}
