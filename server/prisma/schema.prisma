generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ActivityType {
  PR_REVIEWED
  PR_RAISED
  ISSUE_RAISED
  PR_CLOSED
  ISSUE_CLOSED
  COMMENTED
  MERGED
  OTHER
}

enum ActivityStatus {
  OPEN
  CLOSED
  MERGED
  REVIEWED
  APPROVED
  CHANGES_REQUESTED
  COMMENTED
  DRAFT
  OTHER
}

enum ReviewType {
  COMMENTED
  APPROVED
  CHANGES_REQUESTED
  REQUESTED_REVIEW
  NOT_APPLICABLE
}

enum ClosingReason {
  DUPLICATE
  STALE
  INVALID
  COMPLETED
  FIXED_IN_ANOTHER_PR
  NOT_REPRODUCIBLE
  AUTHOR_CLOSED
  MAINTAINER_CLOSED
  NOT_APPLICABLE
  OTHER
}

enum DataSource {
  MANUAL
  GITHUB_SYNC
  IMPORTED
}

enum ActivityReactionType {
  LIKE
  FIRE
  CLAP
  EYES
}

enum ActivityShareTarget {
  COPY_LINK
  X
  LINKEDIN
  OTHER
}

enum WebhookProcessingStatus {
  RECEIVED
  PROCESSED
  SKIPPED
  FAILED
}

enum AuthProvider {
  GOOGLE
  GITHUB
}

enum UserRole {
  ADMIN
  VIEWER
}

model User {
  id            String          @id @default(cuid())
  name          String
  username      String          @unique
  email         String          @unique
  passwordHash  String
  passwordSetAt DateTime?
  emailVerifiedAt DateTime?
  role          UserRole        @default(VIEWER)
  bio           String?         @db.Text
  githubUrl     String?
  linkedinUrl   String?
  xUrl           String?
  leetcodeUrl    String?
  portfolioUrl  String?
  usernameUpdatedAt DateTime?
  skills        Json?
  mainOrganizations Json?
  activities    Activity[]
  organizations Organization[]
  repositories  Repository[]
  pins          Pin[]
  scheduledWork ScheduledWork[]
  goals         Goal[]
  following     Follow[]        @relation("UserFollowing")
  followers     Follow[]        @relation("UserFollowers")
  notifications Notification[]  @relation("UserNotifications")
  sentNotifications Notification[] @relation("NotificationActor")
  githubIntegration GitHubIntegration?
  authAccounts  AuthAccount[]
  emailVerificationOtps EmailVerificationOtp[]
  activityReactions ActivityReaction[]
  activityComments ActivityComment[]
  activityBookmarks ActivityBookmark[]
  activityShares ActivityShare[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model AuthAccount {
  id                    String       @id @default(cuid())
  userId                String
  provider              AuthProvider
  providerAccountId     String
  providerEmail         String?
  accessTokenEncrypted  String?      @db.Text
  refreshTokenEncrypted String?      @db.Text
  expiresAt             DateTime?
  scope                 String?
  tokenType             String?
  profile               Json?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  user                  User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@unique([userId, provider])
  @@index([userId])
  @@index([providerEmail])
}

model EmailVerificationOtp {
  id           String    @id @default(cuid())
  userId       String
  codeHash     String
  expiresAt    DateTime
  consumedAt   DateTime?
  attemptCount Int       @default(0)
  createdAt    DateTime  @default(now())
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([consumedAt])
}

model Follow {
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  follower    User     @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId])
  @@index([followingId])
}

enum GoalMetric {
  PR_RAISED
  PR_REVIEWED
  ISSUE_RAISED
  ISSUE_CLOSED
  REPO_CONTRIBUTIONS
  TOTAL_ACTIVITY
  STREAK
}

enum GoalPeriod {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
  CUSTOM
}

model Goal {
  id          String     @id @default(cuid())
  userId      String
  title       String
  metric      GoalMetric
  target      Int
  period      GoalPeriod @default(MONTHLY)
  startsAt    DateTime?
  endsAt      DateTime?
  isCompleted Boolean    @default(false)
  completedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([metric])
  @@index([period])
}

enum NotificationType {
  SYSTEM
  SOCIAL
  GOAL
  SCHEDULE
  BADGE
  REMINDER
}

model Notification {
  id          String           @id @default(cuid())
  recipientId String
  actorId     String?
  type        NotificationType @default(SYSTEM)
  title       String
  body        String           @db.Text
  metadata    Json?
  readAt      DateTime?
  createdAt   DateTime         @default(now())
  recipient   User             @relation("UserNotifications", fields: [recipientId], references: [id], onDelete: Cascade)
  actor       User?            @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([recipientId])
  @@index([actorId])
  @@index([type])
  @@index([createdAt])
}

enum PinCategory {
  REPOSITORY
  ISSUE
  PULL_REQUEST
  DOCUMENTATION
  PROJECT_BOARD
  ORGANIZATION
  WEBSITE
  OTHER
}

enum ScheduledWorkType {
  PR_REVIEW
  ISSUE_WORK
  PR_TO_RAISE
  ISSUE_TO_RAISE
  BUG_FIX
  FEATURE_BUILD
  DOCUMENTATION
  TESTING
  OTHER
}

enum ScheduledWorkStatus {
  PLANNED
  IN_PROGRESS
  BLOCKED
  DONE
  CANCELLED
  POSTPONED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum WorkDifficulty {
  EASY
  MEDIUM
  HARD
}

model Pin {
  id             String      @id @default(cuid())
  userId         String
  title          String
  url            String
  description    String?     @db.Text
  category       PinCategory @default(WEBSITE)
  customCategory String?
  iconUrl        String?
  faviconUrl     String?
  imageUrl       String?
  isFavorite     Boolean     @default(false)
  isArchived     Boolean     @default(false)
  tags           Json?
  sortOrder      Int         @default(0)
  lastOpenedAt   DateTime?
  source         DataSource  @default(MANUAL)
  externalId     String?
  githubNodeId   String?
  syncedAt       DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([source])
  @@index([externalId])
  @@index([githubNodeId])
  @@index([category])
  @@index([isFavorite])
  @@index([createdAt])
  @@unique([userId, source, externalId])
}

model ScheduledWork {
  id               String              @id @default(cuid())
  userId           String
  title            String
  type             ScheduledWorkType
  status           ScheduledWorkStatus @default(PLANNED)
  priority         Priority            @default(MEDIUM)
  organizationName String
  repositoryName   String
  itemNumber       Int?
  itemUrl          String?
  assignedToMe     Boolean             @default(false)
  assignedSince    DateTime?
  startDate        DateTime?
  dueDate          DateTime?
  completedAt      DateTime?
  estimatedHours   Float?
  actualHours      Float?
  labels           Json?
  tags             Json?
  difficulty       WorkDifficulty?
  context          String?             @db.Text
  plan             String?             @db.Text
  blockers         String?             @db.Text
  closingNotes     String?             @db.Text
  source           DataSource          @default(MANUAL)
  externalId       String?
  githubNodeId     String?
  syncedAt         DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  user             User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([source])
  @@index([externalId])
  @@index([githubNodeId])
  @@index([status])
  @@index([priority])
  @@index([type])
  @@index([dueDate])
  @@index([assignedToMe])
  @@unique([userId, source, externalId])
}

model Activity {
  id                       String         @id @default(cuid())
  userId                   String
  date                     DateTime
  activityType             ActivityType
  title                    String
  number                   String?
  link                     String?
  status                   ActivityStatus @default(OTHER)
  reviewType               ReviewType     @default(NOT_APPLICABLE)
  closingReason            ClosingReason  @default(NOT_APPLICABLE)
  description              String?        @db.Text
  notes                    String?        @db.Text
  tags                     Json?
  organizationId           String?
  repositoryId             String?
  organizationNameSnapshot String
  repositoryNameSnapshot   String
  source                   DataSource     @default(MANUAL)
  externalId               String?
  githubNodeId             String?
  syncedAt                 DateTime?
  organization             Organization?  @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  repository               Repository?    @relation(fields: [repositoryId], references: [id], onDelete: SetNull)
  user                     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  reactions                ActivityReaction[]
  comments                 ActivityComment[]
  bookmarks                ActivityBookmark[]
  shares                   ActivityShare[]
  createdAt                DateTime       @default(now())
  updatedAt                DateTime       @updatedAt

  @@index([userId])
  @@index([source])
  @@index([externalId])
  @@index([githubNodeId])
  @@index([date])
  @@index([activityType])
  @@index([organizationId])
  @@index([repositoryId])
  @@unique([userId, source, externalId])
}

model Organization {
  id           String       @id @default(cuid())
  userId       String
  name         String
  website      String?
  githubUrl    String?
  description  String?      @db.Text
  source       DataSource   @default(MANUAL)
  externalId   String?
  githubNodeId String?
  syncedAt     DateTime?
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  repositories Repository[]
  activities   Activity[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@unique([userId, name])
  @@unique([userId, source, externalId])
  @@index([userId])
  @@index([source])
  @@index([externalId])
  @@index([githubNodeId])
}

model Repository {
  id               String        @id @default(cuid())
  userId           String
  organizationId   String
  name             String
  githubUrl        String?
  description      String?       @db.Text
  primaryTechStack String?
  isActive         Boolean       @default(true)
  source           DataSource    @default(MANUAL)
  externalId       String?
  githubNodeId     String?
  syncedAt         DateTime?
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization     Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  activities       Activity[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@unique([userId, organizationId, name])
  @@unique([userId, source, externalId])
  @@index([userId])
  @@index([organizationId])
  @@index([source])
  @@index([externalId])
  @@index([githubNodeId])
}

model GitHubIntegration {
  id                   String    @id @default(cuid())
  userId               String    @unique
  githubUserId         String    @unique
  login                String
  accessTokenEncrypted String    @db.Text
  tokenType            String?
  scope                String?
  lastSyncedAt         DateTime?
  syncCursor           DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([login])
}

model GitHubWebhookDelivery {
  id          String                  @id @default(cuid())
  deliveryId  String                  @unique
  event       String
  action      String?
  status      WebhookProcessingStatus @default(RECEIVED)
  error       String?                 @db.Text
  payload     Json?
  processedAt DateTime?
  createdAt   DateTime                @default(now())

  @@index([event])
  @@index([status])
  @@index([createdAt])
}

model ActivityReaction {
  id         String               @id @default(cuid())
  activityId String
  userId     String
  type       ActivityReactionType
  createdAt  DateTime             @default(now())
  activity   Activity             @relation(fields: [activityId], references: [id], onDelete: Cascade)
  user       User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([activityId, userId, type])
  @@index([activityId])
  @@index([userId])
}

model ActivityComment {
  id         String    @id @default(cuid())
  activityId String
  userId     String
  body       String    @db.Text
  deletedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  activity   Activity  @relation(fields: [activityId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([activityId])
  @@index([userId])
  @@index([createdAt])
}

model ActivityBookmark {
  activityId String
  userId     String
  createdAt  DateTime @default(now())
  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([activityId, userId])
  @@index([userId])
}

model ActivityShare {
  id         String              @id @default(cuid())
  activityId String
  userId     String
  target     ActivityShareTarget @default(COPY_LINK)
  createdAt  DateTime            @default(now())
  activity   Activity            @relation(fields: [activityId], references: [id], onDelete: Cascade)
  user       User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([activityId])
  @@index([userId])
  @@index([createdAt])
}
